# Python / test artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Local environment and secret material
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*.kubeconfig

# Local databases and state
*.db
*.sqlite
*.sqlite3
/data/
/backups/
/tmp/

# Kubernetes live secret manifests. Keep *.example.yaml templates trackable.
k8s/**/secret.yaml
k8s/**/*-secret.yaml
!k8s/**/*-secret.example.yaml

# Temporary/generated troubleshooting artifacts
/tmp*
/temp*
/execution*.json
*.b64
*.log

# OS/editor noise
Thumbs.db
Desktop.ini
.DS_Store
.idea/
.vscode/
